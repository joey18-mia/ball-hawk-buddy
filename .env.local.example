# Copy this file to ".env.local" and fill in values from your Supabase project
# (Project Settings -> API). These NEXT_PUBLIC_ vars are exposed to the browser,
# which is correct ONLY for the anon key + URL.
#
# NEVER put the service-role key in a NEXT_PUBLIC_ variable or anywhere
# client-side. It is not used by this app at all in Phase 1.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Public base URL of the app (used for auth email redirect links).
# Local dev default shown; set to your Vercel URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
